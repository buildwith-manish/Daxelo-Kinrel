{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [],
    "watchAssets": false,
    "tsConfigPath": "tsconfig.build.json"
  },
  "exclude": [
    "src/app/**/*",
    "src/components/**/*",
    "src/hooks/**/*",
    "src/styles/**/*",
    "src/proxy.ts",
    "src/lib/**/*"
  ]
}
