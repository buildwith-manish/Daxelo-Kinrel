{
  "name": "daxelo-kinrel",
  "version": "1.0.0",
  "private": true,
  "description": "DAXELO KINREL — Family Relationship Intelligence Platform",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "server:dev": "cd server && bun run start:dev",
    "server:build": "cd server && bun run build",
    "server:start": "cd server && bun run start:prod",
    "db:push": "cd server && npx prisma db push",
    "db:generate": "cd server && npx prisma generate",
    "db:migrate": "cd server && npx prisma migrate dev",
    "flutter:build:android": "cd Daxelo-Kinrel-App && flutter build apk --release",
    "flutter:build:ios": "cd Daxelo-Kinrel-App && flutter build ios --release",
    "flutter:run": "cd Daxelo-Kinrel-App && flutter run",
    "flutter:pub": "cd Daxelo-Kinrel-App && flutter pub get"
  },
  "dependencies": {
    "@radix-ui/react-toast": "^1.2.15",
    "@tailwindcss/postcss": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.15",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "z-ai-web-dev-sdk": "^0.0.18"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "typescript": "6.0.3"
  }
}
