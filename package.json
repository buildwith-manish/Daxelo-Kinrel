{
  "name": "daxelo-kinrel",
  "version": "1.0.0",
  "private": true,
  "description": "DAXELO KINREL — Family Relationship Intelligence Platform",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "cd Daxelo-Kinrel-Server && npm run db:push",
    "db:generate": "cd Daxelo-Kinrel-Server && npm run db:generate",
    "db:migrate": "cd Daxelo-Kinrel-Server && npm run db:migrate",
    "flutter:build:android": "cd Daxelo-Kinrel-App && flutter build apk --release",
    "flutter:build:ios": "cd Daxelo-Kinrel-App && flutter build ios --release",
    "flutter:run": "cd Daxelo-Kinrel-App && flutter run",
    "flutter:pub": "cd Daxelo-Kinrel-App && flutter pub get"
  },
  "dependencies": {
    "@radix-ui/react-toast": "^1.2.15",
    "@tailwindcss/postcss": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "z-ai-web-dev-sdk": "^0.0.18"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "typescript": "6.0.3"
  }
}
