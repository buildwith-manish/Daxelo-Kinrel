# ── App ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_URL=https://api.daxelo.com

# ── Database (PostgreSQL) ─────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/daxelo

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=<min 64 char random string>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<min 64 char random string>
JWT_REFRESH_EXPIRES_IN=7d

# ── Cloudinary ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Firebase ──────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Razorpay ──────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=info
LOGTAIL_TOKEN=

# ── Rate Limiting ─────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=200
