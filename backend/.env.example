# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/kinrel?schema=public

# JWT
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# NestJS
PORT=3001
CORS_ORIGIN=*

# NextAuth (for backward compat during transition)
NEXTAUTH_SECRET=change-me-in-production

# Firebase
FIREBASE_SERVICE_ACCOUNT_JSON=

# Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info
LOGTAIL_TOKEN=
