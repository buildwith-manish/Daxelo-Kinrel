# =============================================================================
# Daxelo-Kinrel — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control — API keys must stay in environment
# variables only.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────
# Local development: use SQLite
DATABASE_URL=file:./dev.db
# Production (Supabase PostgreSQL): set both DATABASE_URL and DIRECT_URL
# DATABASE_URL=postgresql://postgres.promxswvsnvilplmrtsj:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# DIRECT_URL=postgresql://postgres.promxswvsnvilplmrtsj:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-secret-here
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_URL=https://your-project.supabase.co

# ── AI ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Notifications ─────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# ── Payments ──────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your-key-id
RAZORPAY_KEY_SECRET=your-key-secret
STRIPE_SECRET_KEY=your-stripe-key

# ── Storage ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://kinrel.app,https://app.kinrel.app
