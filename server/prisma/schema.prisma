// DAXELO KINREL — Prisma Schema
// Pack 01: Design System + Pack 02: Support & Operations + Pack 04: WhatsApp Platform
// Pack 06: Accessibility + Pack 07: Developer API + Pack 08: Content Moderation
// Pack 09: Community & Social + Pack 12: Brand & Motion
// + Family-Graph-First Redesign

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Core Models ──────────────────────────────────────────────────────

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String?
  username          String?  @unique // Unique @username for display
  passwordHash      String?  // bcrypt hash for credentials auth (was SHA-256, now auto-upgraded)
  avatarUrl         String?  // User profile avatar (base64 data URL or remote URL)
  photoThumb        String?  // Avatar thumb: w_80,h_80,c_fill,q_auto,f_auto
  photoCard         String?  // Avatar card: w_150,h_150,c_fill,q_auto,f_auto
  photoFull         String?  // Avatar full: w_400,h_400,c_fill,q_auto,f_webp
  bio               String?  // Short biography
  dateOfBirth       DateTime? // User's date of birth
  gender            String?  // male, female, other, prefer_not_to_say
  profileVisibility String   @default("public") // public, private, connections_only
  invitePermission  String   @default("anyone") // anyone, connections, nobody
  authProvider      String   @default("email") // email, google, apple, phone
  blockedUserIds    String   @default("[]") // JSON array of blocked user IDs
  twoFactorEnabled  Boolean  @default(false) // Whether 2FA is enabled
  twoFactorSecret   String?  // TOTP base32 secret for 2FA
  preferredLanguage String   @default("en")
  role              String   @default("user") // user, admin, agent
  phone             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subscription      Subscription?
  supportTickets    SupportTicket[]
  supportAgent      SupportAgent?
  authoredArticles  KBArticle[]      @relation("KBArticleAuthor")
  editedArticles    KBArticle[]      @relation("KBArticleEditor")
  onCallSchedules   OnCallSchedule[]
  incidents         Incident[]      @relation("IncidentAuthor")
  whatsappConsent   WhatsAppConsent?
  notificationPrefs NotificationPreference[]
  notifications     Notification[]
  sentInvitations   Invitation[]    @relation("InvitationInviter")
  families          FamilyMember[]
  apiKeys           ApiKey[]
  oauthClients      OAuthClient[]
  communityMemberships CommunityMember[]
  communityPosts    CommunityPost[]
  reactions         Reaction[]
  comments          Comment[]
  eventRSVPs        EventRSVP[]
  contributions     UserContribution[]
  userBadges        UserBadge[]
  contentReports    ContentReport[]  @relation("ReportsMade")
  resolvedReports   ContentReport[]  @relation("ReportsResolved")
  moderationActions ModerationAction[]
  moderationStatus  UserModerationStatus?
  parentalConsents  ParentalConsent[]
  appealAppellant   ModerationAppeal[] @relation("AppealAppellant")
  appealReviewer    ModerationAppeal[] @relation("AppealReviewer")
  refreshTokens     RefreshToken[]
  fcmTokens         FcmToken[]
  usernameChangeLog UsernameChangeLog[]
}

// ── Pack 02: Subscription & Support Tier ─────────────────────────────

model Subscription {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  plan        String   @default("free") // free, pro_monthly, pro_annual, family_annual, lifetime
  status      String   @default("active") // active, cancelled, expired
  supportTier String   @default("basic") // basic, standard, premium, vip
  startDate   DateTime @default(now())
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets     SupportTicket[] @relation("SupportTicketSubscription")

  @@index([userId, status])
  @@index([supportTier])
}

// ── Pack 02: Support Agent ───────────────────────────────────────────

model SupportAgent {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  name            String
  email           String
  phone           String?

  // Agent configuration (stored as JSON strings)
  status          String   @default("offline") // online, busy, offline, break
  queues          String   @default("[]") // JSON array: ["billing","technical","critical"]
  minTier         Int      @default(1) // Minimum tier weight this agent handles
  languages       String   @default("[]") // JSON array: ["en","hi"]

  // Load tracking
  currentLoad     Int      @default(0)
  maxLoad         Int      @default(10)

  // Schedule
  onCallUntil     DateTime?
  nextShift       DateTime?

  // Stats
  avgResponseTime   Int    @default(0) // minutes
  avgResolutionTime Int    @default(0) // minutes
  satisfactionScore Float  @default(0) // 0-5
  ticketsResolved   Int    @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignedTickets SupportTicket[] @relation("AssignedAgent")

  @@index([status, currentLoad])
}

// ── Pack 02: Ticketing System ────────────────────────────────────────

model SupportTicket {
  id              String   @id @default(cuid())
  ticketNumber    String   @unique // DK-2024-00001
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  // Classification
  category        String   @default("general") // billing, account, data_loss, bug, feature_request, general, matrimonial, verification, privacy
  subcategory     String?
  severity        String   @default("medium") // critical, high, medium, low
  priority        Int      @default(1) // 1-100

  // Content
  subject         String
  description     String
  attachments     String   @default("[]") // JSON array of URLs
  appVersion      String?
  platform        String?  // android, ios, web
  deviceInfo      String?  // JSON string

  // State
  status          String   @default("open") // open, in_progress, waiting_customer, waiting_third_party, resolved, closed
  resolution      String?
  resolutionType  String?  // resolved, wont_fix, duplicate, no_response, out_of_scope

  // Subscription reference
  subscription    Subscription?  @relation("SupportTicketSubscription", fields: [userId], references: [userId])

  // Assignment
  assignedAgentId String?
  assignedAgent   SupportAgent? @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  queue           String   @default("general")

  // SLA tracking
  slaTier         String   @default("basic")
  firstResponseAt DateTime?
  firstResponseDeadline DateTime?
  resolutionDeadline DateTime?
  slaBreached     Boolean  @default(false)

  // Language
  language        String   @default("en")

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  resolvedAt      DateTime?
  closedAt        DateTime?

  // Relations
  messages        SupportMessage[]
  escalations     SupportEscalation[]
  csat            SupportCSAT?
  slaRecords      SLATracking[]

  @@index([userId, status])
  @@index([assignedAgentId, status])
  @@index([status, priority])
  @@index([category, status])
  @@index([slaBreached])
  @@index([createdAt])
}

model SupportMessage {
  id              String   @id @default(cuid())
  ticketId        String
  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  senderType      String   @default("user") // user, agent, system
  senderId        String?
  senderName      String

  content         String
  attachments     String   @default("[]") // JSON array
  isInternal      Boolean  @default(false)

  // Metadata
  channel         String   @default("in_app") // in_app, email, whatsapp, phone
  language        String   @default("en")

  createdAt       DateTime @default(now())

  @@index([ticketId, createdAt])
}

model SupportEscalation {
  id              String   @id @default(cuid())
  ticketId        String
  ticket          SupportTicket @relation(fields: [ticketId], references: [id])

  fromAgentId     String?
  toAgentId       String?
  reason          String   // sla_breach, complexity, user_request, supervisor_review
  notes           String?

  createdAt       DateTime @default(now())

  @@index([ticketId])
}

model SupportCSAT {
  id              String   @id @default(cuid())
  ticketId        String   @unique
  ticket          SupportTicket @relation(fields: [ticketId], references: [id])

  rating          Int      // 1-5
  comment         String?
  createdAt       DateTime @default(now())
}

// ── Pack 02: SLA Tracking ────────────────────────────────────────────

model SLATracking {
  id              String   @id @default(cuid())
  ticketId        String?
  ticket          SupportTicket? @relation(fields: [ticketId], references: [id])

  // SLA type
  type            String   // first_response, update, resolution, uptime
  tier            String   // basic, standard, premium, vip

  // Deadlines
  deadline        DateTime
  metAt           DateTime?
  breached        Boolean  @default(false)
  breachDuration  Int?     // Minutes past deadline

  // Uptime-specific
  downtimeStart   DateTime?
  downtimeEnd     DateTime?
  downtimeMinutes Int?

  createdAt       DateTime @default(now())

  @@index([type, tier, breached])
  @@index([deadline])
}

// ── Pack 02: On-Call Rotation ────────────────────────────────────────

model OnCallSchedule {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  role            String   // primary, secondary
  weekStart       DateTime // Monday 00:00 IST
  weekEnd         DateTime // Sunday 23:59 IST

  // Tracking
  incidentsHandled Int     @default(0)
  avgAckTime      Int      @default(0) // seconds
  avgResolveTime  Int      @default(0) // minutes
  compensationPaid Boolean @default(false)

  createdAt       DateTime @default(now())

  @@unique([userId, weekStart, role])
  @@index([weekStart, role])
}

// ── Pack 02: Incident Communication ──────────────────────────────────

model Incident {
  id              String   @id @default(cuid())
  incidentNumber  String   @unique // INC-2024-00001
  title           String
  description     String

  // Status
  status          String   @default("investigating") // investigating, identified, monitoring, resolved
  severity        String   // critical, high, medium, low

  // Affected components (JSON array)
  affectedComponents String @default("[]")

  // Timeline
  startedAt       DateTime @default(now())
  identifiedAt    DateTime?
  monitoringAt    DateTime?
  resolvedAt      DateTime?

  // Communication
  initialNotificationSent Boolean @default(false)
  resolutionNotificationSent Boolean @default(false)

  // Author
  authorId        String
  author          User     @relation("IncidentAuthor", fields: [authorId], references: [id])

  // Post-mortem
  postMortem      PostMortem?

  updates         IncidentUpdate[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, startedAt])
  @@index([severity, status])
}

model IncidentUpdate {
  id              String   @id @default(cuid())
  incidentId      String
  incident        Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  status          String   // investigating, identified, monitoring, resolved
  message         String
  authorId        String
  authorName      String

  createdAt       DateTime @default(now())

  @@index([incidentId, createdAt])
}

model PostMortem {
  id              String   @id @default(cuid())
  incidentId      String   @unique
  incident        Incident @relation(fields: [incidentId], references: [id])

  // Sections
  summary         String
  timeline        String
  rootCause       String
  impact          String
  whatWentWell    String
  whatWentWrong   String
  actionItems     String   @default("[]") // JSON array

  // Meta
  authorId        String
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  @@index([completedAt])
}

model IncidentSubscriber {
  id              String   @id @default(cuid())
  email           String?
  phone           String?  // WhatsApp number
  userId          String?

  createdAt       DateTime @default(now())

  @@index([email])
  @@index([phone])
}

// ── Pack 02: Knowledge Base ──────────────────────────────────────────

model KBArticle {
  id              String   @id @default(cuid())
  slug            String   @unique

  // Category
  category        String   @default("general") // getting_started, family_tree, relationships, subscriptions, matrimonial, whatsapp, privacy, account, troubleshooting
  subcategory     String?
  sortOrder       Int      @default(0)

  // Content (localized JSON strings)
  title           String   @default("{}") // JSON: {"en": "...", "hi": "..."}
  content         String   @default("{}") // JSON: {"en": "...", "hi": "..."}
  excerpt         String   @default("{}") // JSON: {"en": "...", "hi": "..."}

  // Metadata
  tags            String   @default("[]") // JSON array
  relatedArticleIds String @default("[]") // JSON array

  // Status
  status          String   @default("draft") // draft, published, archived
  featured        Boolean  @default(false)

  // Analytics
  views           Int      @default(0)
  helpfulYes      Int      @default(0)
  helpfulNo       Int      @default(0)
  searchAppearances Int    @default(0)
  clickThroughs   Int      @default(0)

  // Authorship
  authorId        String
  author          User     @relation("KBArticleAuthor", fields: [authorId], references: [id])
  lastEditedById  String?
  lastEditedBy    User?    @relation("KBArticleEditor", fields: [lastEditedById], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  publishedAt     DateTime?

  searchLogs      KBSearchLog[]

  @@index([category, status, sortOrder])
  @@index([status, publishedAt])
}

model KBSearchLog {
  id              String   @id @default(cuid())
  query           String
  language        String   @default("en")
  userId          String?

  // Results
  resultsCount    Int
  clickedArticleId String?
  clickedArticle   KBArticle? @relation(fields: [clickedArticleId], references: [id])

  // Did this search lead to a support ticket?
  ledToTicket     Boolean  @default(false)

  createdAt       DateTime @default(now())

  @@index([query, language])
  @@index([createdAt])
  @@index([ledToTicket])
}

// ── Pack 04: WhatsApp Platform ──────────────────────────────────────

// Family & Person models (foundation for WhatsApp features + Graph-First redesign)

model Family {
  id              String   @id @default(cuid())
  name            String
  description     String?
  primaryLanguage String   @default("en")
  gotra           String?  // Hindu gotra identifier
  originVillage   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // ── Graph-First Redesign Fields ──
  familyCode      String   @unique @default(cuid()) // Shareable family ID like Instagram handle
  kinFamilyId     String?  @unique // Human-readable Family ID: KIN-AB12CD34 (Feature 1: Family ID System)
  username        String?  @unique // Unique @username for display (e.g. @sharmw)
  avatarUrl       String?
  region          String?
  privacyMode     String   @default("private") // private/invite/link
  isOnboarded     Boolean  @default(false)
  anchorPersonId  String?  // The primary household anchor person
  memberCount     Int      @default(0)
  generationCount Int      @default(1)
  lastActivityAt  DateTime @default(now())
  createdBy       String?  // User ID who created this family

  members         FamilyMember[]
  persons         Person[]
  invitations     Invitation[]
  familyInvites   FamilyInvite[]
  graphLayouts    GraphLayoutState[]
  graphChangeLogs GraphChangeLog[]
  feedPosts       FamilyPost[]

  @@index([name])
  @@index([familyCode])
  @@index([username])
  @@index([kinFamilyId])
}

model FamilyMember {
  id              String   @id @default(cuid())
  familyId        String
  userId          String
  role            String   @default("member") // owner, admin, member, viewer

  family          Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id])

  joinedAt        DateTime @default(now())

  createdInvites  FamilyInvite[]

  @@unique([familyId, userId])
  @@index([familyId])
  @@index([userId])
}

model Person {
  id              String   @id @default(cuid())
  familyId        String
  name            String
  dateOfBirth     DateTime?
  gotra           String?
  occupation      String?
  city            String?
  isDeceased      Boolean  @default(false)
  privacyLevel    String   @default("family") // family, extended, public
  deletedAt       DateTime? // Soft delete — null means active

  // ── Graph-First Redesign Fields ──
  birthYear       Int?
  notes           String?
  sideOfFamily    String?  // paternal/maternal/both
  generationIndex Int      @default(0)
  isAnchor        Boolean  @default(false)
  photoUrl        String?
  photoThumb      String?  // Photo thumb: w_80,h_80,c_fill,q_auto,f_auto
  photoCard       String?  // Photo card: w_150,h_150,c_fill,q_auto,f_auto
  photoFull       String?  // Photo full: w_400,h_400,c_fill,q_auto,f_webp
  gender          String?  // male, female, other
  username        String?  // Unique @username for display

  // ── Full Member Profile Fields ──
  bloodGroup      String?  // A+, A-, B+, B-, AB+, AB-, O+, O-
  education       String?  // Education details
  biography       String?  // Long biography text
  email           String?  // Contact email
  phone           String?  // Contact phone
  address         String?  // Contact address (JSON: {street, city, state, country, zip})
  anniversaryDate DateTime? // Marriage/wedding anniversary

  family          Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)

  relationshipsFrom Relationship[] @relation("RelationshipFrom")
  relationshipsTo   Relationship[] @relation("RelationshipTo")

  feedPosts       FamilyPost[]
  privacySettings PersonPrivacySetting?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([familyId, name])
  @@index([familyId, dateOfBirth])
  @@index([deletedAt])
  @@index([familyId, generationIndex])
  @@index([username])
  @@index([familyId])
  @@index([updatedAt])
}

// WhatsApp Template Management

model WhatsAppTemplate {
  id              String   @id @default(cuid())
  name            String   @unique
  category        String   // AUTHENTICATION, UTILITY, MARKETING, SERVICE
  status          String   @default("pending") // pending, approved, rejected, paused
  whatsappId      String?  // Meta's template ID
  languages       String   @default("[]") // JSON array of language codes
  components      String   @default("{}") // JSON: template components
  rejectionReason String?
  lastSyncedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([category])
}

// WhatsApp Consent & Opt-in (DPDP Act compliance)

model WhatsAppConsent {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  phone           String
  optedIn         Boolean  @default(false)
  optInMethod     String?  // app_settings, onboarding, invite_flow, customer_service
  optInAt         DateTime?
  optOutAt        DateTime?
  optOutMethod    String?  // whatsapp_stop, app_settings, account_deletion
  optOutReason    String?
  consentVersion  String   @default("v1")
  messageCategories String   @default("[]") // JSON array of consented categories
  marketingConsent Boolean @default(false)
  marketingOptInAt DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([phone])
  @@index([optedIn])
}

// WhatsApp Per-Template Opt-In

model WhatsAppOptIn {
  id              String   @id @default(cuid())
  phone           String
  templateType    String   // birthday_reminder, new_match, family_invite, etc.
  optedIn         Boolean  @default(false)
  optedInAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([phone, templateType])
  @@index([phone])
}

// WhatsApp Analytics Events

model WhatsAppAnalytics {
  id              String   @id @default(cuid())
  event           String   // whatsapp.message.sent, .delivered, .read, .replied, .failed, .opt_in.completed, .opt_out.requested, .deep_link.tapped, .card.generated, .card.shared, .invite.accepted
  userId          String?
  familyId        String?
  messageId       String?
  templateId      String?
  metadata        String   @default("{}") // JSON
  createdAt       DateTime @default(now())

  @@index([event, createdAt])
  @@index([userId, createdAt])
  @@index([templateId, createdAt])
}

// Notification Preferences (per user, per event type)

model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String
  eventType       String
  whatsapp        Boolean  @default(true)
  push            Boolean  @default(true)
  inApp           Boolean  @default(true)
  email           Boolean  @default(false)
  quietHoursStart String?  // "22:00"
  quietHoursEnd   String?  // "08:00"
  quietHoursTimezone String @default("Asia/Kolkata")
  maxPerDay       Int      @default(10)
  digestMode      String   @default("immediate") // immediate, hourly, daily

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, eventType])
  @@index([userId])
}

// Notification Records

model Notification {
  id              String   @id @default(cuid())
  userId          String
  eventType       String
  title           String
  body            String
  familyId        String?
  personId        String?
  channels        String   @default("[]") // JSON array: ["whatsapp","push","inApp","email"]
  priority        String   @default("normal") // critical, high, normal, low
  read            Boolean  @default(false)
  readAt          DateTime?
  actionUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updates         NotificationUpdate[]

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
}

// Notification Delivery Tracking (per channel)

model NotificationUpdate {
  id              String   @id @default(cuid())
  notificationId  String
  notification    Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel         String   // whatsapp, push, inApp, email, sms
  status          String   // pending, delivered, failed, read
  error           String?
  createdAt       DateTime @default(now())

  @@index([notificationId])
  @@index([channel, status])
}

// Family Invitations (WhatsApp + Email)

model Invitation {
  id              String   @id @default(cuid())
  token           String   @unique
  familyId        String
  inviterId       String
  inviter         User     @relation("InvitationInviter", fields: [inviterId], references: [id])
  family          Family   @relation(fields: [familyId], references: [id])

  // Recipient
  recipientEmail  String?
  recipientPhone  String?
  recipientName   String?

  // State
  status          String   @default("pending") // pending, accepted, expired, cancelled
  role            String   @default("member") // admin, editor, member, viewer
  channel         String   @default("email") // email, whatsapp, direct_link

  // Pre-fill data for onboarding
  preFilledData   String   @default("{}") // JSON: {name, phone, suggestedRelation}

  // WhatsApp-specific tracking
  whatsappSentAt        DateTime?
  whatsappReminderCount Int     @default(0)
  whatsappLastRemindedAt DateTime?
  deepLinkPath          String?

  // Timestamps
  acceptedAt      DateTime?
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([familyId, status])
  @@index([recipientPhone])
  @@index([token])
  @@index([status, createdAt])
}

// Shareable Links (for rich media cards)

model ShareableLink {
  id              String   @id @default(cuid())
  token           String   @unique
  cardType        String   // family_tree, birthday, anniversary, memorial, milestone, relationship_discovery, festival_greeting
  familyId        String?
  personId        String?
  title           String
  description     String
  deepLinkUrl     String
  viewCount       Int      @default(0)
  shareCount      Int      @default(0)
  expiresAt       DateTime?
  createdAt       DateTime @default(now())

  @@index([token])
  @@index([cardType])
}

// ══════════════════════════════════════════════════════════════════════
// Pack 07: Developer / Public API
// ══════════════════════════════════════════════════════════════════════

model ApiKey {
  id              String   @id @default(cuid())
  name            String
  keyPrefix       String   // First 12 chars: "kin_live_XXXX"
  keyHash         String   // SHA-256 hash of the full key
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopes          String   @default("[]") // JSON array: ["families:read","persons:read"]
  tier            String   @default("free") // free, pro, enterprise
  rateLimitPerMinute Int   @default(30)
  allowedOrigins  String   @default("[]") // JSON array
  allowedIps      String   @default("[]") // JSON array
  lastUsedAt      DateTime?
  expiresAt       DateTime?
  revokedAt       DateTime?
  revokeReason    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([keyPrefix, keyHash])
  @@index([userId])
  @@index([keyPrefix])
  @@index([tier])
}

model OAuthClient {
  id              String   @id @default(cuid())
  clientId        String   @unique
  clientSecret    String
  name            String
  description     String?
  redirectUris    String   @default("[]") // JSON array
  scopes          String   @default("[]") // JSON array
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  logoUrl         String?
  websiteUrl      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientId])
}

model OAuthAuthorizationCode {
  id              String   @id @default(cuid())
  code            String   @unique
  clientId        String
  userId          String
  scopes          String   @default("[]") // JSON array
  redirectUri     String
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  @@index([code])
  @@index([expiresAt])
}

model IdempotencyKey {
  id              String   @id @default(cuid())
  key             String   @unique
  responseBody    String
  responseStatus  Int
  responseHeaders String   @default("{}") // JSON
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  @@index([key])
  @@index([expiresAt])
}

model WebhookSubscription {
  id              String   @id @default(cuid())
  userId          String
  url             String
  secret          String   // For HMAC signature verification
  events          String   @default("[]") // JSON array: ["person.created","relationship.created"]
  active          Boolean  @default(true)
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deliveries      WebhookDelivery[]

  @@index([userId])
  @@index([active])
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  webhookId       String
  webhook         WebhookSubscription @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  eventId         String
  eventType       String
  payload         String   // JSON string
  signature       String   // HMAC-SHA256
  attemptCount    Int      @default(0)
  maxAttempts     Int      @default(5)
  status          String   @default("pending") // pending, delivered, failed, ignored
  lastAttemptAt   DateTime?
  nextAttemptAt   DateTime?
  responseStatusCode Int?
  responseBody    String?
  createdAt       DateTime @default(now())

  @@index([webhookId])
  @@index([status])
  @@index([nextAttemptAt])
}

model AuditLog {
  id              String   @id @default(cuid())
  userId          String?
  action          String   // API_KEY_CREATED, API_KEY_REVOKED, etc.
  resource        String   // ApiKey, Person, Family
  resourceId      String?
  details         String   @default("{}") // JSON
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([resource, resourceId])
}

model Relationship {
  id              String   @id @default(cuid())
  familyId        String
  fromPersonId    String
  toPersonId      String
  relationshipKey String   // Kinship key e.g. "fathers_sister", "spouse", "child" — renamed from "type"
  relationshipType String  @default("custom") // father, mother, son, daughter, brother, sister, husband, wife, custom
  direction       String   @default("from") // from: fromPerson is the type of toPerson (e.g. from=father means fromPerson is father of toPerson)
  isActive        Boolean  @default(true)
  label           String?  // Custom user-defined label override
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  fromPerson      Person   @relation("RelationshipFrom", fields: [fromPersonId], references: [id], onDelete: Cascade)
  toPerson        Person   @relation("RelationshipTo", fields: [toPersonId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([fromPersonId])
  @@index([toPersonId])
  @@index([relationshipKey])
}

// ── Family Feed (Instagram-style family moments) ──────────────────────

model FamilyPost {
  id          String   @id @default(cuid())
  familyId    String
  authorId    String   // Person ID who authored/is the subject of this post
  postType    String   // "relationship_discovered" | "member_joined" | "milestone" | "connection_added" | "invite_shared"
  content     String   @default("{}") // JSON string for each post type's flexible data
  reactions   String   @default("{}") // JSON: { heart: 0, comment: 0, isHearted: false, isSaved: false }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  family      Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  author      Person   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([familyId, createdAt])
  @@index([postType])
  @@index([authorId])
  @@index([updatedAt])
}

// ══════════════════════════════════════════════════════════════════════
// Pack 08: Content Moderation
// ══════════════════════════════════════════════════════════════════════

model ModerationCase {
  id              String   @id @default(cuid())
  contentType     String   // person_biography, family_story, photo, profile_photo, etc.
  contentId       String
  contentPreview  String?  // First 500 chars or thumbnail
  contentHash     String?  // For deduplication
  authorId        String
  familyId        String?

  // Classification
  category        String   @default("safe") // safe, borderline, harassment, hate_speech, violence, sexual_content, csam, pii_exposure, spam, etc.
  confidence      Float    @default(0.0)
  autoAction      String   @default("allow") // allow, allow_with_flag, quarantine, reject, escalate
  flaggedCategories String @default("[]") // JSON array

  // Status
  status          String   @default("pending") // pending, under_review, actioned, appealed, dismissed, escalated
  priority        String   @default("normal") // low, normal, high, urgent, critical

  // Review
  reviewerId      String?
  reviewedAt      DateTime?
  reviewDecision  String?  // uphold, dismiss, escalate
  reviewNotes     String?

  // Source
  source          String   @default("auto") // auto, user_report, proactive, admin
  reporterId      String?
  reportReason    String?
  reportDetails   String?

  // Actions taken
  contentAction   String?  // none, hidden, removed, replaced, user_suspended, user_banned

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  actions         ModerationActionItem[]
  appeals         ModerationAppeal[]

  @@index([status, priority])
  @@index([contentType, contentId])
  @@index([authorId])
  @@index([createdAt])
  @@index([reviewerId])
}

model ModerationActionItem {
  id              String   @id @default(cuid())
  caseId          String
  modCase         ModerationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  actionType      String   // auto_allow, auto_quarantine, auto_reject, reported, reviewed, appealed
  actorId         String?
  details         String?  // JSON
  createdAt       DateTime @default(now())

  @@index([caseId])
}

model ModerationRule {
  id              String   @id @default(cuid())
  name            String
  description     String?
  contentType     String?
  category        String
  condition       String   // JSON: rule conditions
  action          String   // Auto-action to take
  priority        String   @default("normal")
  isActive        Boolean  @default(true)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive, category])
}

model ModerationAppeal {
  id              String   @id @default(cuid())
  caseId          String
  modCase         ModerationCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  appellantId     String
  appealReason    String
  appealTier      Int      @default(1) // 1 or 2
  status          String   @default("pending") // pending, under_review, upheld, reinstated, reduced, dismissed
  reviewerId      String?
  reviewedAt      DateTime?
  reviewDecision  String?
  reviewNotes     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appellant       User     @relation("AppealAppellant", fields: [appellantId], references: [id])
  reviewer        User?    @relation("AppealReviewer", fields: [reviewerId], references: [id])

  @@index([caseId])
  @@index([appellantId])
  @@index([status])
}

model ContentReport {
  id              String   @id @default(cuid())
  reporterId      String
  reporter        User     @relation("ReportsMade", fields: [reporterId], references: [id])
  targetType      String   // post, comment, community, user
  targetId        String
  reason          String   // spam, harassment, hate_speech, caste_reference, misinformation, etc.
  description     String?
  status          String   @default("pending") // pending, reviewing, resolved, dismissed
  resolvedById    String?
  resolvedBy      User?    @relation("ReportsResolved", fields: [resolvedById], references: [id])
  resolution      String?  // content_removed, user_banned, user_warned, dismissed, escalated
  resolutionNote  String?
  createdAt       DateTime @default(now())
  resolvedAt      DateTime?

  @@index([status, createdAt])
  @@index([targetType, targetId])
  @@index([reporterId])
}

model ModerationAction {
  id              String   @id @default(cuid())
  moderatorId     String
  moderator       User     @relation(fields: [moderatorId], references: [id])
  targetType      String   // post, comment, user, community
  targetId        String
  action          String   // hide, delete, warn, suspend, ban, lock, pin
  reason          String
  duration        Int?     // Suspension duration in hours
  reportId        String?
  createdAt       DateTime @default(now())
  expiresAt       DateTime?

  @@index([targetType, targetId])
  @@index([moderatorId])
  @@index([expiresAt])
}

model UserModerationStatus {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  status          String   @default("active") // active, warned, suspended, banned
  warningCount    Int      @default(0)
  suspendedUntil  DateTime?
  banReason       String?
  lastWarnedAt    DateTime?
  lastActionAt    DateTime?

  @@index([status])
}

model ModerationAuditLog {
  id              String   @id @default(cuid())
  action          String   // classify, review, approve, reject, appeal, reinstate
  contentType     String   // image, text, profile, voice
  contentId       String
  actorType       String   // system, ai_classifier, human_moderator, admin
  actorId         String?
  result          String   // allow, review, reject, restrict
  reason          String?
  confidence      Float?
  metadata        String   @default("{}") // JSON
  createdAt       DateTime @default(now())

  @@index([contentId, createdAt])
  @@index([actorType, actorId])
  @@index([createdAt])
}

model ParentalConsent {
  id              String   @id @default(cuid())
  childPersonId   String
  guardianUserId  String
  consentType     String   // data_processing, photo_upload, health_data, education_data
  consented       Boolean  @default(false)
  consentMethod   String   // in_app, email_verification, whatsapp_verification
  consentGivenAt  DateTime?
  ipAddress       String?
  userAgent       String?
  revokedAt       DateTime?
  createdAt       DateTime @default(now())

  guardian        User     @relation(fields: [guardianUserId], references: [id], onDelete: Cascade)

  @@index([childPersonId])
  @@index([guardianUserId])
}

// ══════════════════════════════════════════════════════════════════════
// Pack 09: Community & Social
// ══════════════════════════════════════════════════════════════════════

model Community {
  id              String   @id @default(cuid())
  type            String   // gotra, village, surname, custom
  name            String
  slug            String   @unique
  description     String?
  coverImageUrl   String?
  iconUrl         String?
  isVerified      Boolean  @default(false)
  isPrivate       Boolean  @default(false)
  memberCount     Int      @default(0)
  postCount       Int      @default(0)
  gotraName       String?
  villageName     String?
  surname         String?
  region          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members         CommunityMember[]
  posts           CommunityPost[]
  events          CommunityEvent[]
  rules           CommunityRule[]

  @@index([type, name])
  @@index([slug])
}

model CommunityMember {
  id              String   @id @default(cuid())
  communityId     String
  community       Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            String   @default("member") // member, moderator, admin, banned
  joinedAt        DateTime @default(now())
  joinedVia       String?  // auto_gotra, invitation, search, suggestion
  lastReadAt      DateTime?

  @@unique([communityId, userId])
  @@index([userId])
}

model CommunityPost {
  id              String   @id @default(cuid())
  communityId     String?
  community       Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  familyId        String?
  authorId        String
  author          User     @relation(fields: [authorId], references: [id])
  type            String   @default("text") // text, photo, event, announcement, milestone, memorial
  title           String?
  body            String
  mediaUrls       String   @default("[]") // JSON array
  visibility      String   @default("members") // public, members, family_only
  isPinned        Boolean  @default(false)
  isLocked        Boolean  @default(false)
  isHidden        Boolean  @default(false)
  hiddenReason    String?
  metadata        String?  // JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reactions       Reaction[]
  comments        Comment[]

  @@index([communityId, createdAt])
  @@index([familyId, createdAt])
  @@index([authorId])
  @@index([visibility, createdAt])
}

model Reaction {
  id              String   @id @default(cuid())
  postId          String
  post            CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji           String   // Unicode emoji
  createdAt       DateTime @default(now())

  @@unique([postId, userId, emoji])
  @@index([postId])
}

model Comment {
  id              String   @id @default(cuid())
  postId          String
  post            CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId        String
  author          User     @relation(fields: [authorId], references: [id])
  parentId        String?  // For threaded replies
  body            String
  isHidden        Boolean  @default(false)
  hiddenReason    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([postId, createdAt])
  @@index([parentId])
  @@index([authorId])
}

model FamilyConnection {
  id              String   @id @default(cuid())
  fromFamilyId    String
  toFamilyId      String
  status          String   @default("pending") // pending, accepted, blocked
  connectionType  String?  // sagotra, same_village, inter_marriage, manual
  requestedById   String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([fromFamilyId, toFamilyId])
  @@index([toFamilyId, status])
  @@index([fromFamilyId, status])
}

model CommunityEvent {
  id              String   @id @default(cuid())
  familyId        String?
  communityId     String?
  creatorId       String
  title           String
  description     String?
  eventType       String   @default("custom") // puja, wedding, engagement, birthday, shraddh, grah_pravesh, naming, upanayana, festival, custom
  startDate       DateTime
  endDate         DateTime?
  isAllDay        Boolean  @default(false)
  isRecurring     Boolean  @default(false)
  recurrenceRule  String?  // RFC 5545 RRULE
  location        String?
  locationUrl     String?
  meetingUrl      String?
  visibility      String   @default("family") // family, community, public
  isCancelled     Boolean  @default(false)
  coverImageUrl   String?
  metadata        String?  // JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  community       Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  rsvps           EventRSVP[]
  reminders       EventReminder[]

  @@index([familyId, startDate])
  @@index([startDate])
}

model EventRSVP {
  id              String   @id @default(cuid())
  eventId         String
  event           CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          String   @default("pending") // pending, attending, maybe, declined
  plusOne         Boolean  @default(false)
  note            String?
  respondedAt     DateTime @default(now())

  @@unique([eventId, userId])
  @@index([eventId])
}

model EventReminder {
  id              String   @id @default(cuid())
  eventId         String
  event           CommunityEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId          String
  remindAt        DateTime
  isSent          Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([remindAt, isSent])
}

model CommunityRule {
  id              String   @id @default(cuid())
  communityId     String
  community       Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  title           String
  description     String
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([communityId, sortOrder])
}

// ── Pack 09: Leaderboard & Gamification ──────────────────────────────

model UserContribution {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId        String
  personsAdded    Int      @default(0)
  relationshipsAdded Int   @default(0)
  photosAdded     Int      @default(0)
  eventsCreated   Int      @default(0)
  storiesShared   Int      @default(0)
  commentsWritten Int      @default(0)
  invitationsSent Int      @default(0)
  personsEdited   Int      @default(0)
  totalPoints     Int      @default(0)
  level           Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, familyId])
  @@index([familyId, totalPoints])
}

model Badge {
  id              String   @id @default(cuid())
  slug            String   @unique // "first_person", "centurion", etc.
  name            String
  nameHi          String?
  description     String
  icon            String   // Emoji or icon name
  category        String   // tree_builder, connector, historian, social, special
  tier            String   @default("bronze") // bronze, silver, gold, platinum
  threshold       Int      // Point threshold
  isSecret        Boolean  @default(false)
  createdAt       DateTime @default(now())

  userBadges      UserBadge[]

  @@index([category])
}

model UserBadge {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId         String
  badge           Badge    @relation(fields: [badgeId], references: [id])
  familyId        String?
  earnedAt        DateTime @default(now())

  @@unique([userId, badgeId, familyId])
  @@index([userId])
}

model FamilyMilestone {
  id              String   @id @default(cuid())
  familyId        String
  milestone       String   // "10_members", "50_members", "5_generations"
  reachedAt       DateTime @default(now())
  celebrated      Boolean  @default(false)

  @@unique([familyId, milestone])
}

// ── Pack 09: Privacy Boundaries ─────────────────────────────────────

model PersonPrivacySetting {
  id              String   @id @default(cuid())
  personId        String   @unique
  person          Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  // ── Existing Privacy Fields ──
  visibility      String   @default("family") // family_only, extended, public
  searchable      Boolean  @default(true)
  matrimonialEligible Boolean @default(true)
  communityFeatures Boolean @default(true)
  minorFlag       Boolean  @default(false)
  photoConsent    Boolean  @default(true)
  healthConsent   Boolean  @default(false)
  gotraVisibility String   @default("family") // self, admin, family, hidden

  // ── New Privacy Controls ──
  showPhone       Boolean  @default(false)
  showEmail       Boolean  @default(false)
  showAddress     Boolean  @default(false)
  showDob         Boolean  @default(true)
  showAge         Boolean  @default(true)
  showOccupation  Boolean  @default(true)
  showEducation   Boolean  @default(true)
  showBloodGroup  Boolean  @default(false)
  showAnniversary Boolean  @default(false)
  profileVisibleTo String @default("family") // family, extended, public

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([visibility])
  @@index([minorFlag])
}

model DataAccessLog {
  id              String   @id @default(cuid())
  personId        String
  viewerId        String
  viewerRole      String   // self, admin, member, extended, public
  fieldAccessed   String   // name, photo, health, gotra, etc.
  granted         Boolean
  reason          String?
  createdAt       DateTime @default(now())

  @@index([personId, createdAt])
  @@index([viewerId])
}

model PhotoConsent {
  id              String   @id @default(cuid())
  personId        String
  photoUrl        String
  consentedBy     String   // userId who gave consent
  consentType     String   // explicit, inferred_denied
  revokedAt       DateTime?
  createdAt       DateTime @default(now())

  @@index([personId])
}

// ══════════════════════════════════════════════════════════════════════
// Family-Graph-First Redesign: New Models
// ══════════════════════════════════════════════════════════════════════

// ── Family Invite (code/link-based sharing) ────────────────────────

model FamilyInvite {
  id              String   @id @default(uuid())
  familyId        String
  invitedBy       String   // FamilyMember id
  inviteCode      String   @unique @default(cuid())
  role            String   @default("viewer") // admin/editor/member/viewer
  status          String   @default("pending") // pending, accepted, rejected, expired
  inviteType      String   @default("link") // family_id, qr_code, link
  maxUses         Int      @default(1)
  currentUses     Int      @default(0)
  useCount        Int      @default(0)
  expiresAt       DateTime?
  createdAt       DateTime @default(now())

  family          Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  inviterMember   FamilyMember @relation(fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([inviteCode])
}

// ── Graph Layout State (user visualization preferences) ─────────────

model GraphLayoutState {
  id              String   @id @default(uuid())
  familyId        String
  userId          String
  layoutMode      String   @default("tree") // tree/radial/force
  nodePositions   Json     // {personId: {x, y}}
  collapsedNodes  Json     // [personId, ...]
  hiddenNodes     Json     // [personId, ...]
  zoomLevel       Float    @default(1.0)
  panOffset       Json     // {x, y}
  filters         Json     // {generation, branch, bloodline, marital}
  updatedAt       DateTime @updatedAt

  family          Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
}

// ── Graph Change Log (audit trail) ─────────────────────────────────

model GraphChangeLog {
  id              String   @id @default(uuid())
  familyId        String
  userId          String
  action          String   // person_added/person_removed/relationship_added/relationship_removed/family_merged/branch_split
  entityType      String   // person/relationship/family
  entityId        String
  details         Json     // snapshot of change
  createdAt       DateTime @default(now())

  family          Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([userId])
}

// ── Relationship Type Metadata (enriched kinship metadata) ──────────

model RelationshipTypeMetadata {
  id              String   @id @default(uuid())
  relationshipKey String   @unique // "fathers_sister"
  englishLabel    String   // "Father's Sister"
  gender          String   // male/female/neutral
  lineage         String   // paternal/maternal/marital/sibling
  generation      Int      // 0=same, +1=elder, -1=younger
  relationCategory String  // blood/marital/affinal
  inverseKey      String   // "nephew_niece"
  pathComponents  Json     // ["father", "sister"]
  category        String   // "paternal_uncles_aunts"
  isCompound      Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([relationshipKey])
  @@index([category])
  @@index([lineage])
}

// ── Auth: Refresh Token Store ──────────────────────────────────────

model RefreshToken {
  id          String   @id @default(cuid())
  token       String   @unique
  userId      String
  familyId    String   // Token family for rotation
  expiresAt   DateTime
  revokedAt   DateTime?
  userAgent   String?  // Browser/device user-agent string for session tracking
  ipAddress   String?  // IP address at time of token creation
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([familyId])
}

// ── FCM Push Notification Tokens ───────────────────────────────────

model FcmToken {
  id              String   @id @default(cuid())
  token           String   @unique // FCM device registration token
  userId          String
  deviceType      String   @default("unknown") // android, ios, web, unknown
  createdAt       DateTime @default(now())
  lastUsedAt      DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([lastUsedAt])
}

// ── Feature Flags ──────────────────────────────────────────────

model FeatureFlag {
  id          String   @id @default(cuid())
  name        String   @unique
  enabled     Boolean  @default(false)
  rolloutPct  Int      @default(0)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ══════════════════════════════════════════════════════════════════════
// Pack: Sync, Path Cache & AI Features
// ══════════════════════════════════════════════════════════════════════

// ── Sync Log (offline sync tracking) ─────────────────────────────────

model SyncLog {
  id              String   @id @default(cuid())
  userId          String
  familyId        String?
  syncType        String   // full, delta, reconnect
  lastSyncedAt    DateTime @default(now())
  entitiesSynced  Int      @default(0)
  conflictsCount  Int      @default(0)
  resolvedCount   Int      @default(0)
  status          String   @default("completed") // completed, failed, partial
  errorMessage    String?
  createdAt       DateTime @default(now())

  @@index([userId, familyId])
  @@index([userId, lastSyncedAt])
}

// ── Relationship Path Cache (computed kinship paths) ──────────────────

model RelationshipPathCache {
  id              String   @id @default(cuid())
  familyId        String
  fromPersonId    String
  toPersonId      String
  path            String   // JSON array of {personId, relationshipType} steps
  kinshipTerm     String?  // Computed term like "cousin"
  kinshipTermHi   String?  // Hindi translation
  distance        Int      // Number of hops
  computedAt      DateTime @default(now())
  expiresAt       DateTime @default(now())

  @@unique([familyId, fromPersonId, toPersonId])
  @@index([familyId])
  @@index([fromPersonId])
  @@index([toPersonId])
  @@index([expiresAt])
}

// ── AI Interaction (AI features tracking) ────────────────────────────

model AiInteraction {
  id              String   @id @default(cuid())
  userId          String
  familyId        String?
  personId        String?
  interactionType String   // explain_relationship, family_summary, history_summary, smart_search
  prompt          String
  response        String
  modelUsed       String   @default("gemini-flash")
  tokenCount      Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([interactionType])
}

// ── Username Change Log (audit trail for username changes) ───────────

model UsernameChangeLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  oldUsername   String?  // null if no previous username
  newUsername   String
  changedAt     DateTime @default(now())

  @@index([userId, changedAt])
  @@index([newUsername])
}

