# =============================================================================
# DAXELO KINREL — Root .gitignore
# =============================================================================

# Environment — NEVER commit these
.env
.env.*
!.env.example
.env.local
.env.production
.env.staging
**/.env
**/.env.local
server/.env
Daxelo-Kinrel-App/.env

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*

# Databases
*.db
*.db-journal
*.sqlite
*.sqlite3
db/
**/db/custom.db

# Logs
*.log
dev.log
dev.out.log
server.log

# NestJS build
Daxelo-Kinrel-Server/dist/
server/dist/
server/node_modules/

# Flutter
Daxelo-Kinrel-App/build/
Daxelo-Kinrel-App/.dart_tool/
Daxelo-Kinrel-App/.flutter-plugins
Daxelo-Kinrel-App/.flutter-plugins-dependencies
Daxelo-Kinrel-App/.packages
Daxelo-Kinrel-App/.pub-cache/
Daxelo-Kinrel-App/.pub/
Daxelo-Kinrel-App/ios/Pods/
Daxelo-Kinrel-App/ios/.symlinks/
Daxelo-Kinrel-App/android/.gradle/
Daxelo-Kinrel-App/android/app/build/
Daxelo-Kinrel-App/lib/**/*.g.dart
Daxelo-Kinrel-App/lib/**/*.freezed.dart

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
*.pem

# Android signing — NEVER commit keystore files
*.jks
*.keystore
Daxelo-Kinrel-App/android/key.properties
Daxelo-Kinrel-App/android/app/upload-keystore.jks

# TypeScript
*.tsbuildinfo

# Debug
npm-debug.log*
yarn-debug.log*
.pnpm-debug.log*

# =============================================================================
# Dev Platform / AI Context (NOT part of the app)
# =============================================================================
.zscripts/
agent-ctx/
skills/
upload/
download/
examples/
docs/runbooks/
style_dictionary/
.claude
.z-ai-config
worklog.md
worklog_new.md
local-*

# =============================================================================
# Legacy directories (removed during restructuring - only ignore at root level)
# =============================================================================
/flutter_app/
/src/
/prisma/
/public/
/mini-services/
/db/
.next/
.env
upload/
