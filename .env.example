# ============================================================
# Daxelo-KinRel — Environment Variables Reference
# Copy this file as `.env` and fill in the [PLACEHOLDER] values
# ============================================================

# ──────────────────────────────────────────────────────────────
# 1. SUPABASE POSTGRESQL  (Required)
# ──────────────────────────────────────────────────────────────
# Prisma uses two connection strings for Supabase:
#   - DATABASE_URL  → Pooled connection (Supavisor) for runtime queries
#   - DIRECT_URL    → Direct connection for migrations & introspection
#
# Find these in: Supabase Dashboard → Settings → Database → Connection string
#
# Pooled (Supavisor) — port 6543, user = postgres.<project-ref>
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-DB-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:6543/postgres

# Direct — port 5432, user = postgres
DIRECT_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ──────────────────────────────────────────────────────────────
# 2. SUPABASE CLIENT KEYS  (Required for auth / client SDK)
# ──────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Settings → API

# Project URL (safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co

# Public anon key (safe for client-side, protected by Row Level Security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR-ANON-KEY]

# Service role key (SERVER-SIDE ONLY — bypasses RLS, NEVER expose to browser)
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SERVICE-ROLE-KEY]

# ──────────────────────────────────────────────────────────────
# 3. APP URL  (Optional — has fallback)
# ──────────────────────────────────────────────────────────────
# Base URL of the deployed application.
# Used for deep links, invite URLs, share cards, and OG meta tags.
# Defaults to "https://daxelo.app" if not set.
# NEXT_PUBLIC_APP_URL=https://daxelo.app

# ──────────────────────────────────────────────────────────────
# 4. WHATSAPP BUSINESS API  (Optional — app runs without them)
# ──────────────────────────────────────────────────────────────
# All WhatsApp variables are optional with empty-string fallbacks.
# The app gracefully disables all WhatsApp features when these are empty
# (WhatsAppClient.isConfigured() returns false).
#
# Fill them in ONLY if you want WhatsApp invitation messaging to work.

# Meta WhatsApp Business API base URL
# Defaults to "https://graph.facebook.com/v18.0"
# WHATSAPP_API_URL=https://graph.facebook.com/v18.0

# Meta WhatsApp Business Phone Number ID
# Found in: Meta Business Suite → Phone Numbers
# WHATSAPP_PHONE_NUMBER_ID=

# Bearer token for WhatsApp Business API (Authorization header)
# Found in: Meta Business Suite → System Users → Access Tokens
# WHATSAPP_ACCESS_TOKEN=

# Token used to verify incoming WhatsApp webhooks
# You set this yourself in: Meta Dashboard → Webhooks → Verify Token
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Meta App Secret for HMAC-SHA256 webhook signature verification
# Found in: Meta App Dashboard → App Settings → Basic → App Secret
# WHATSAPP_APP_SECRET=

# WhatsApp Business Account ID (for template creation API)
# Found in: Meta Business Suite → Business Settings → Business Accounts
# WHATSAPP_BUSINESS_ID=
