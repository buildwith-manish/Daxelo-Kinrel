# ============================================================
# Daxelo Kinrel — Environment Variables Reference
# Copy this file as `.env` and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ── 1. SUPABASE POSTGRESQL (Required) ────────────────────────
# Find in: Supabase Dashboard → Settings → Database → Connection string

# Pooled connection (Supavisor) — port 6543
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[DB-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Direct connection — port 5432 (for migrations)
DIRECT_URL=postgresql://postgres:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── 2. SUPABASE KEYS (Required) ──────────────────────────────
# Find in: Supabase Dashboard → Settings → API

SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=[YOUR-ANON-KEY]
SUPABASE_JWT_SECRET=[YOUR-JWT-SECRET]

# Service role key (SERVER-SIDE ONLY — bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SERVICE-ROLE-KEY]

# ── 3. NESTJS AUTH (Required) ─────────────────────────────────

JWT_ACCESS_SECRET=[YOUR-JWT-ACCESS-SECRET]
JWT_REFRESH_EXPIRATION=7d

# ── 4. AI (Optional — app runs without them) ──────────────────

GEMINI_API_KEY=[YOUR-GEMINI-API-KEY]

# ── 5. FIREBASE / FCM (Optional — push notifications) ────────

FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── 6. CLOUDINARY (Optional — image uploads) ──────────────────

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── 7. WHATSAPP BUSINESS API (Optional — invite messaging) ────

WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_BUSINESS_ID=

# ── 8. PAYMENTS (Optional — Razorpay / Stripe) ────────────────

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=

# ── 9. CORS (Optional — defaults to localhost in dev) ────────

CORS_ORIGINS=https://kinrel.app,https://app.kinrel.app

# ── 10. APP URL (Optional — deep links, share cards) ─────────

APP_URL=https://kinrel.app
