# =============================================================================
# Daxelo-Kinrel NestJS Server — Production Environment Template
# =============================================================================
#
# Deployment Target : Oracle Cloud VPS (Docker)
# CDN / Proxy       : Cloudflare
# Database          : Supabase PostgreSQL
# Auth              : Supabase Auth + JWT
# Storage           : Supabase Storage / Cloudinary
# Caching           : Redis (via Docker Compose service)
# Monitoring        : Sentry + BetterStack
#
# HOW TO USE:
#   1. Copy this file to .env.production
#   2. Replace every <PLACEHOLDER> with real production values
#   3. NEVER commit .env.production to version control
#   4. Rotate all secrets immediately if any leak is suspected
#
# SECURITY NOTES:
#   - All secrets must be at least 32 characters; JWT secrets must be 64-char hex
#   - Use `openssl rand -hex 32` to generate secure random values
#   - Supabase keys are found in Project Settings → API
#   - The SERVICE_ROLE_KEY bypasses RLS — guard it carefully
#
# =============================================================================


# ── Server Config ────────────────────────────────────────────────────────────
# Core application settings for the NestJS runtime inside the Docker container.
# PORT must be 3001 to match the EXPOSE directive in the Dockerfile and the
# port mapping defined in docker-compose.yml.

NODE_ENV=production
PORT=3001
API_PREFIX=api
FRONTEND_URL=https://kinrel.app


# ── Database (Supabase) ─────────────────────────────────────────────────────
# Supabase provides managed PostgreSQL with two connection modes:
#   - DATABASE_URL  : Pooled connection via PgBouncer (port 6543).
#                     Used by the app at runtime for scalable concurrent access.
#   - DIRECT_URL    : Direct connection (port 5432).
#                     Used by Prisma CLI for migrations and introspection only.
# Both URLs follow the format:
#   postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:[PORT]/postgres

DATABASE_URL=
DIRECT_URL=


# ── Authentication ──────────────────────────────────────────────────────────
# JWT tokens for stateless auth issued by the NestJS server.
# Access tokens are short-lived; refresh tokens are long-lived.
# Generate each secret with:  openssl rand -hex 32
# (produces a 64-character hex string)

JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRATION=7d


# ── OAuth ───────────────────────────────────────────────────────────────────
# Google OAuth 2.0 for social sign-in.
# Obtain credentials from Google Cloud Console → APIs & Services → Credentials.
# The callback URL must match exactly what is registered in Google and must
# route through Cloudflare to the NestJS /api/auth/google/callback endpoint.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.kinrel.app/api/auth/google/callback


# ── Supabase ────────────────────────────────────────────────────────────────
# Supabase project credentials for Auth, Storage, and Realtime integration.
# Find these in Supabase Dashboard → Project Settings → API.
#   - ANON_KEY         : Public-facing key (safe for client use, enforces RLS)
#   - JWT_SECRET       : Used to verify Supabase-issued JWTs server-side
#   - SERVICE_ROLE_KEY : Full admin access, bypasses all RLS — NEVER expose

SUPABASE_URL=https://promxswvsnvilplmrtsj.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=


# ── AI Features ─────────────────────────────────────────────────────────────
# API key for the z-ai-web-dev-sdk used by AI-powered modules:
#   - AI Chat, AI Voice, AI Cards, Content Moderation
# Keep this key server-side only — never expose to the client.

Z_AI_API_KEY=


# ── Media Storage ───────────────────────────────────────────────────────────
# Cloudinary credentials for image and video upload/transform.
# Find these in Cloudinary Dashboard → Account Details.
# Used for family photos, profile avatars, and AI-generated card images.

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# ── Email ───────────────────────────────────────────────────────────────────
# SMTP configuration for transactional emails (verification, password reset,
# invitations, etc.). Using Gmail SMTP with an App Password is the simplest
# setup; for high volume, consider a dedicated transactional email provider.
# Generate a Gmail App Password: Google Account → Security → App passwords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=


# ── Payments ────────────────────────────────────────────────────────────────
# Payment gateway credentials for premium subscriptions and in-app purchases.
#   - Razorpay : Primary gateway for India (INR)
#   - Stripe   : International payments (USD, EUR, etc.)
# Stripe webhook secret is generated when you create a webhook endpoint
# in the Stripe Dashboard → Developers → Webhooks.

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# ── CORS & Redis ────────────────────────────────────────────────────────────
# CORS_ORIGINS: Comma-separated list of allowed origins for cross-origin
#   requests. Includes the production web app (with www variant), and the
#   custom scheme / bundle ID for the native mobile app.
# REDIS_URL: Connection string for the Redis service defined in the
#   docker-compose.yml stack. Uses the Docker service name "redis" as
#   hostname, which resolves within the Docker network.

CORS_ORIGINS=https://kinrel.app,https://www.kinrel.app,capabile://,com.daxelo.kinrel
REDIS_URL=redis://redis:6379


# ── Monitoring ──────────────────────────────────────────────────────────────
# Sentry DSN for real-time error tracking and performance monitoring.
# Create a new Node.js project in Sentry and copy the DSN value.
# BetterStack source token for centralized log aggregation.
# Find this in BetterStack → Sources → Add source.

SENTRY_DSN=
BETTERSTACK_SOURCE_TOKEN=


# ── Firebase ────────────────────────────────────────────────────────────────
# Firebase Admin SDK credentials for FCM push notifications.
#   - PROJECT_ID  : Found in Firebase Console → Project Settings
#   - CLIENT_EMAIL: Service account email from Firebase → Service Accounts
#   - PRIVATE_KEY : Full PEM private key (include \n line breaks in .env)
# Download the service account JSON from Firebase Console and extract values.

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=


# ── Logging ─────────────────────────────────────────────────────────────────
# Structured logging configuration for the production server.
#   - LOG_LEVEL              : Minimum severity to emit (debug|info|warn|error)
#   - LOG_DIR                : Directory inside container for log files
#   - ERROR_RATE_ALERT_THRESHOLD : Alert when error rate exceeds this ratio (1%)
#   - P99_ALERT_THRESHOLD_MS    : Alert when P99 latency exceeds this (ms)

LOG_LEVEL=info
LOG_DIR=/app/logs
ERROR_RATE_ALERT_THRESHOLD=0.01
P99_ALERT_THRESHOLD_MS=2000
